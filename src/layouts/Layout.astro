---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Fuego & Sazón | La Auténtica Cocina Peruana en Lima",
  description = "Restaurante peruano en Miraflores, Lima. Ceviche, lomo saltado, anticuchos y más. Reservas, delivery y una experiencia gastronómica inolvidable."
} = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#1a1a2e" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <slot />
</body>
</html>
