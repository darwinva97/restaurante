<section class="delivery section" id="delivery">
  <div class="container">
    <div class="del-grid">
      <div class="del-content">
        <span class="del-eyebrow">A domicilio</span>
        <h2>Pide tu delivery</h2>
        <div class="gold-divider" style="margin-left:0;"></div>
        <p>Disfruta de nuestros platos en la comodidad de tu hogar. Hacemos delivery a los principales distritos de Lima.</p>

        <div class="del-apps">
          <h4>Pide por tu app favorita</h4>
          <div class="app-badges">
            <span class="app-badge rappi">Rappi</span>
            <span class="app-badge pedidosya">PedidosYa</span>
            <span class="app-badge uber">Uber Eats</span>
          </div>
        </div>

        <div class="del-direct">
          <h4>O p&iacute;delo directamente</h4>
          <div class="del-contacts">
            <a href="tel:014458899" class="del-contact">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              (01) 445-8899
            </a>
            <a href="https://wa.me/51987654321" class="del-contact whatsapp">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              +51 987 654 321
            </a>
          </div>
        </div>
      </div>

      <div class="del-details">
        <div class="del-card">
          <div class="del-card-icon">&#128205;</div>
          <h4>Zona de delivery</h4>
          <ul>
            <li>Miraflores</li>
            <li>San Isidro</li>
            <li>Surco</li>
            <li>Barranco</li>
          </ul>
        </div>
        <div class="del-card">
          <div class="del-card-icon">&#128666;</div>
          <h4>Condiciones</h4>
          <ul>
            <li>Pedido m&iacute;nimo: <strong>S/ 30</strong></li>
            <li>Delivery gratis desde <strong>S/ 80</strong></li>
            <li>Tiempo estimado: 30-45 min</li>
            <li>Empaque eco-friendly</li>
          </ul>
        </div>
        <div class="del-card">
          <div class="del-card-icon">&#9201;</div>
          <h4>Horario delivery</h4>
          <ul>
            <li>Lunes a Jueves: 12 - 21:30</li>
            <li>Viernes a S&aacute;bado: 12 - 22:30</li>
            <li>Domingo: 12 - 20:30</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .del-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .del-eyebrow {
    display: inline-block;
    color: var(--gold);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }
  .del-content h2 { margin-bottom: 0.5rem; }
  .del-content p {
    color: var(--text-light);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }
  .del-apps { margin-bottom: 2rem; }
  .del-apps h4, .del-direct h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--primary);
  }
  .app-badges {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .app-badge {
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius-sm);
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
    letter-spacing: 0.5px;
  }
  .app-badge.rappi { background: #ff441f; }
  .app-badge.pedidosya { background: #d6006e; }
  .app-badge.uber { background: #06c167; }
  .del-contacts {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .del-contact {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    background: var(--warm);
    border-radius: var(--radius-sm);
    font-weight: 600;
    color: var(--primary);
    transition: 0.3s ease;
  }
  .del-contact:hover { transform: translateX(4px); }
  .del-contact.whatsapp { background: #dcf8c6; color: #075e54; }
  .del-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .del-card {
    background: var(--warm);
    padding: 1.5rem 2rem;
    border-radius: var(--radius);
    border-left: 4px solid var(--gold);
  }
  .del-card-icon {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .del-card h4 {
    font-family: 'Playfair Display', serif;
    color: var(--primary);
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }
  .del-card ul li {
    padding: 0.25rem 0;
    color: var(--text-light);
    font-size: 0.95rem;
  }
  @media (max-width: 768px) {
    .del-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
