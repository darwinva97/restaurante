---
const dishes = [
  {
    name: "Ceviche Clásico",
    description: "Pescado fresco marinado en limón, cebolla morada, ají limo y cilantro. Servido con camote y choclo.",
    price: "S/ 38",
    image: "https://images.unsplash.com/photo-1535399831218-d5bd36d1a6b3?w=600&q=80",
  },
  {
    name: "Lomo Saltado",
    description: "Lomo fino salteado al wok con cebolla, tomate, ají amarillo, salsa de soya y papas fritas.",
    price: "S/ 42",
    image: "https://images.unsplash.com/photo-1544025162-d76694265947?w=600&q=80",
  },
  {
    name: "Causa Limeña",
    description: "Capas de papa amarilla prensada con ají amarillo, rellena de pollo o atún con palta.",
    price: "S/ 28",
    image: "https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=600&q=80",
  },
  {
    name: "Ají de Gallina",
    description: "Pollo deshilachado en crema de ají amarillo, nueces y queso. Acompañado de arroz y papa.",
    price: "S/ 35",
    image: "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=600&q=80",
  },
  {
    name: "Arroz con Mariscos",
    description: "Arroz con langostinos, calamares, conchas y pulpo en salsa de mariscos con ají panca.",
    price: "S/ 48",
    image: "https://images.unsplash.com/photo-1534080564583-6be75777b70a?w=600&q=80",
  },
  {
    name: "Anticuchos de Corazón",
    description: "Brochetas de corazón de res marinadas en ají panca, servidas con papas doradas y ají.",
    price: "S/ 32",
    image: "https://images.unsplash.com/photo-1529692236671-f1f6cf9683ba?w=600&q=80",
  },
];
---
<section class="featured-menu section section-warm">
  <div class="container">
    <span class="section-eyebrow">Nuestro Men&uacute;</span>
    <h2 class="section-title">Platos Destacados</h2>
    <div class="gold-divider"></div>
    <p class="section-subtitle">Los favoritos de nuestros comensales, preparados con los mejores ingredientes del d&iacute;a.</p>

    <div class="dishes-grid">
      {dishes.map((dish) => (
        <article class="dish-card">
          <div class="dish-image">
            <img src={dish.image} alt={dish.name} loading="lazy" />
            <div class="dish-price">{dish.price}</div>
          </div>
          <div class="dish-info">
            <h3>{dish.name}</h3>
            <p>{dish.description}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center" style="margin-top:3rem;">
      <a href="/menu/" class="btn btn-primary">Ver Men&uacute; Completo</a>
    </div>
  </div>
</section>

<style>
  .section-eyebrow {
    display: block;
    text-align: center;
    color: var(--gold);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }
  .dishes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .dish-card {
    background: white;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .dish-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }
  .dish-image {
    position: relative;
    height: 220px;
    overflow: hidden;
  }
  .dish-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .dish-card:hover .dish-image img {
    transform: scale(1.08);
  }
  .dish-price {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background: var(--primary);
    color: var(--gold);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .dish-info {
    padding: 1.25rem 1.5rem 1.5rem;
  }
  .dish-info h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: var(--primary);
  }
  .dish-info p {
    color: var(--text-light);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  @media (max-width: 992px) {
    .dishes-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .dishes-grid { grid-template-columns: 1fr; }
  }
</style>
