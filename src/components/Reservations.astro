<section class="reservations section section-dark" id="reservas">
  <div class="container">
    <div class="res-grid">
      <div class="res-info">
        <span class="res-eyebrow">Reservaciones</span>
        <h2>Reserva tu mesa</h2>
        <div class="gold-divider" style="margin-left:0;"></div>
        <p>Asegura tu lugar en Fuego & Saz&oacute;n. Para grupos mayores a 10 personas, cont&aacute;ctanos directamente.</p>

        <div class="res-hours">
          <h4>Horarios de atenci&oacute;n</h4>
          <ul>
            <li><span>Lunes - Jueves</span><span>12:00 - 22:00</span></li>
            <li><span>Viernes - S&aacute;bado</span><span>12:00 - 23:00</span></li>
            <li><span>Domingo</span><span>12:00 - 21:00</span></li>
          </ul>
        </div>

        <div class="res-whatsapp">
          <p>Tambi&eacute;n puedes reservar por WhatsApp:</p>
          <a href="https://wa.me/51987654321" class="btn btn-outline" style="margin-top:0.75rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            +51 987 654 321
          </a>
        </div>
      </div>

      <div class="res-form-wrap">
        <form class="res-form">
          <div class="form-row">
            <div class="form-group">
              <label for="res-name">Nombre completo</label>
              <input type="text" id="res-name" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <label for="res-phone">Tel&eacute;fono</label>
              <input type="tel" id="res-phone" placeholder="+51 999 999 999" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="res-date">Fecha</label>
              <input type="date" id="res-date" required />
            </div>
            <div class="form-group">
              <label for="res-time">Hora</label>
              <select id="res-time" required>
                <option value="">Seleccionar hora</option>
                <option>12:00</option><option>12:30</option>
                <option>13:00</option><option>13:30</option>
                <option>14:00</option><option>14:30</option>
                <option>19:00</option><option>19:30</option>
                <option>20:00</option><option>20:30</option>
                <option>21:00</option><option>21:30</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="res-guests">N&uacute;mero de personas</label>
              <select id="res-guests" required>
                <option value="">Seleccionar</option>
                <option>1 persona</option><option>2 personas</option>
                <option>3 personas</option><option>4 personas</option>
                <option>5 personas</option><option>6 personas</option>
                <option>7-8 personas</option><option>9-10 personas</option>
              </select>
            </div>
            <div class="form-group">
              <label for="res-occasion">Ocasi&oacute;n especial</label>
              <select id="res-occasion">
                <option value="">Ninguna</option>
                <option>Cumplea&ntilde;os</option>
                <option>Aniversario</option>
                <option>Reuni&oacute;n de negocios</option>
                <option>Celebraci&oacute;n</option>
                <option>Otra</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="res-notes">Notas adicionales</label>
            <textarea id="res-notes" rows="3" placeholder="Alergias, preferencias de mesa, etc."></textarea>
          </div>
          <button type="submit" class="btn btn-gold" style="width:100%;margin-top:0.5rem;">Reservar Mesa</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .res-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: start;
  }
  .res-eyebrow {
    display: inline-block;
    color: var(--gold);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }
  .res-info h2 {
    color: white;
    margin-bottom: 0.5rem;
  }
  .res-info p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }
  .res-hours {
    background: rgba(255, 255, 255, 0.05);
    padding: 1.5rem;
    border-radius: var(--radius-sm);
    margin-bottom: 2rem;
  }
  .res-hours h4 {
    color: var(--gold);
    font-size: 1rem;
    margin-bottom: 1rem;
    font-family: 'Playfair Display', serif;
  }
  .res-hours ul li {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.8);
  }
  .res-whatsapp p {
    font-size: 0.95rem !important;
    margin-bottom: 0.5rem !important;
  }
  .res-form-wrap {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius);
    padding: 2.5rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-group {
    margin-bottom: 1rem;
  }
  .form-group label {
    display: block;
    color: var(--gold);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.08);
    color: white;
    font-size: 0.95rem;
    transition: border-color 0.3s ease;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--gold);
  }
  .form-group select option {
    background: var(--primary);
    color: white;
  }
  @media (max-width: 768px) {
    .res-grid { grid-template-columns: 1fr; gap: 2rem; }
    .form-row { grid-template-columns: 1fr; }
    .res-form-wrap { padding: 1.5rem; }
  }
</style>
